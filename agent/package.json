{
  "name": "perf-agent",
  "version": "1.0.0",
  "description": "Lightweight system metrics agent",
  "main": "index.js",
  "bin": "index.js",
  "scripts": {
    "start": "node index.js",
    "build": "pkg . --targets node18-win-x64,node18-macos-x64,node18-linux-x64 --output dist/perf-agent",
    "build:win": "pkg . --targets node18-win-x64 --output dist/perf-agent.exe",
    "build:mac": "pkg . --targets node18-macos-x64 --output dist/perf-agent-macos",
    "build:linux": "pkg . --targets node18-linux-x64 --output dist/perf-agent-linux"
  },
  "pkg": {
    "assets": [],
    "targets": [
      "node18-win-x64",
      "node18-macos-x64",
      "node18-linux-x64"
    ]
  },
  "dependencies": {
    "node-machine-id": "^1.1.12",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.12.0"
  }
}
