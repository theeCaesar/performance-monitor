# ── Agent Configuration ───────────────────────────────────────
# Full URL of the relay server (no trailing slash).
# This is the only required variable.
# Example:
#   MONITOR_SERVER=https://perf-server.onrender.com
MONITOR_SERVER=http://localhost:3000

# Shared secret — must match the server's MONITOR_KEY exactly.
MONITOR_KEY=change-me-before-deploying

# How often (in milliseconds) the agent collects and sends metrics.
# Lower = smoother dashboard, higher = less CPU overhead on the monitored machine.
# Default: 1000 (1 second)
TICK_RATE=1000
