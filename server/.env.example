# ── Server Configuration ─────────────────────────────────────
# Port the HTTP server listens on.
# On Render/Heroku/Railway this is set automatically — leave blank or omit.
PORT=3000

# CORS origin for the dashboard.
# In production set this to your exact dashboard URL, e.g.:
#   DASHBOARD_ORIGIN=https://pulseboard.onrender.com
# Trailing slashes will break the CORS check — omit them.
DASHBOARD_ORIGIN=http://localhost:3001

# Shared secret that agents must present to authenticate.
# Change this before any public deployment.
# Generate a strong value with:  openssl rand -hex 32
MONITOR_KEY=change-me-before-deploying
