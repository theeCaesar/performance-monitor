# ── Dashboard Configuration ───────────────────────────────────
# Full URL of the relay server (no trailing slash).
# Local development:
REACT_APP_SERVER_URL=http://localhost:3000

# Production example (Render):
# REACT_APP_SERVER_URL=https://perf-server.onrender.com

# Note: Create React App only picks up variables prefixed with REACT_APP_.
# After changing this file you must restart `npm start` for the change to take effect.
